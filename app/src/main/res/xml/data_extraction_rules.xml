<?xml version="1.0" encoding="utf-8"?>
<!-- Mesma exclusão do backup_rules.xml, no formato do Android 12+. -->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="sharedpref" path="secure_settings.xml" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="sharedpref" path="secure_settings.xml" />
    </device-transfer>
</data-extraction-rules>
